# A backend (state_sync_websocket) publikus elérhetősége.
#
# Helyi fejlesztéskor üresen hagyhatod – ilyenkor a http://localhost:3031/
# fallback érvényes (lásd src/api/SocketApi.js).
#
# Vercelen a Project Settings > Environment Variables alatt állítsd be a
# hostolt backend URL-jére. FONTOS: https:// (wss://) legyen, különben a
# böngésző mixed-content miatt blokkolja a kapcsolatot.
REACT_APP_SOCKET_URL=https://your-backend-host.example.com
